# Copy this file to .env or set these variables in your shell before running.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_THINKING=disabled
INFLUENCE_MAP_LLM_PROVIDER=deepseek
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REASONING=none
OPENROUTER_JSON_MODE=1
INFLUENCE_MAP_LLM_CONCURRENCY=1
INFLUENCE_MAP_LLM_TIMEOUT_MS=45000
INFLUENCE_MAP_LLM_MAX_TOKENS=
PORT=3000
INFLUENCE_MAP_DATA_FILE=./data/graph.json
INFLUENCE_MAP_DB_FILE=./data/influence-map.sqlite
INFLUENCE_MAP_DEV_TOOLS=0
INFLUENCE_MAP_ADMIN_TOKEN=
